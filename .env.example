# SMTP Email Configuration
SMTP_HOST=mail.activezone.ng
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=orders@activezone.ng
SMTP_PASS=your-email-password
SMTP_FROM_EMAIL=orders@activezone.ng
SMTP_FROM_NAME=Active Zone Hub

# Application URL (update with your production domain)
APP_URL=https://your-domain.com

# Google Authenticator TOTP Secret (for order deletion)
TOTP_SECRET=your-totp-secret

# Paystack Payment Gateway
# For production, replace with live key: sk_live_xxxxx
PAYSTACK_SECRET_KEY=sk_test_cf05b6f83e3ef958938a6adbdfa98103f017d643

# Server Port (optional, defaults to 3001)
PORT=3001
