# Active Zone Hub - Environment Variables Template
# Copy this file to .env and fill in your actual values

# ============================================
# DATABASE CONFIGURATION
# ============================================
# MongoDB Atlas Configuration (required for Vercel)
DATABASE_ENABLED=true
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=activezone

# Get MongoDB URI from: https://cloud.mongodb.com
# 1. Create a free cluster
# 2. Create a database user
# 3. Click "Connect" -> "Connect your application"
# 4. Copy the connection string and replace <password> with your password

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001

# For Vercel, set these in Vercel dashboard:
# NODE_ENV=production
# APP_URL=https://your-domain.vercel.app

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info

# ============================================
# GYM MASTER API
# ============================================
# Contact Active Zone Hub admin for these credentials
GYM_MASTER_API_KEY=YOUR_GYM_MASTER_API_KEY
GYM_MASTER_BASE_URL=https://activezone.gymmasteronline.com/portal
GYM_MASTER_COMPANY_ID=YOUR_COMPANY_ID

# ============================================
# PAYSTACK PAYMENT
# ============================================
# Get your keys from: https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=sk_test_YOUR_TEST_SECRET_KEY
PAYSTACK_PUBLIC_KEY=pk_test_YOUR_TEST_PUBLIC_KEY

# Live keys (for production)
# PAYSTACK_SECRET_KEY=sk_live_YOUR_LIVE_SECRET_KEY
# PAYSTACK_PUBLIC_KEY=pk_live_YOUR_LIVE_PUBLIC_KEY

# ============================================
# BREVO EMAIL SERVICE
# ============================================
# Get your API key from: https://app.brevo.com/settings/keys-api
BREVO_API_KEY=YOUR_BREVO_API_KEY
SMTP_FROM_EMAIL=your-email@example.com
SMTP_FROM_NAME=Active Zone Hub

# ============================================
# ADMIN AUTHENTICATION
# ============================================
# Password for admin login on orders.html
ADMIN_PASSWORD=ActiveZone@2026

# ============================================
# SECURITY - TOTP (Google Authenticator)
# ============================================
# Generate a secret by running: node -e "console.log(require('speakeasy').generateSecret().base32)"
TOTP_SECRET=YOUR_TOTP_SECRET
TOTP_SECRET_ADMIN=YOUR_ADMIN_TOTP_SECRET

