# Active Zone Hub - Environment Variables Template
# Copy this file to .env and fill in your actual values

# ============================================
# DATABASE CONFIGURATION
# ============================================
# AWS RDS PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://activeadmin:YOUR_PASSWORD@your-rds-endpoint.region.rds.amazonaws.com:5432/activezone

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=production
PORT=3001
APP_URL=https://your-domain.com

# ============================================
# GYM MASTER API
# ============================================
GYM_MASTER_API_KEY=7adf342b0c2124f391d4b7934e8430bb
GYM_MASTER_BASE_URL=https://activezone.gymmasteronline.com/portal
GYM_MASTER_COMPANY_ID=1152997

# ============================================
# PAYSTACK PAYMENT
# ============================================
# Test keys (for development)
PAYSTACK_SECRET_KEY=sk_test_cf05b6f83e3ef958938a6adbdfa98103f017d643
PAYSTACK_PUBLIC_KEY=pk_test_95c8da16fbb2c8f8a8fe0d8c72945e7b76fcd144

# Live keys (for production - uncomment and use these)
# PAYSTACK_SECRET_KEY=sk_live_YOUR_LIVE_SECRET_KEY
# PAYSTACK_PUBLIC_KEY=pk_live_YOUR_LIVE_PUBLIC_KEY

# ============================================
# BREVO EMAIL SERVICE
# ============================================
BREVO_API_KEY=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
SMTP_FROM_EMAIL=fusionflowltd@gmail.com
SMTP_FROM_NAME=Active Zone Hub

# ============================================
# SECURITY - TOTP (Google Authenticator)
# ============================================
# Generate a secret by running: node -e "console.log(require('speakeasy').generateSecret().base32)"
# Or visit: http://localhost:3001/api/totp/setup after first run
TOTP_SECRET=YOUR_TOTP_SECRET_HERE

# ============================================
# OPTIONAL: MONITORING & LOGGING
# ============================================
# AWS CloudWatch (optional)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key

# ============================================
# DEPLOYMENT PLATFORM DETECTION
# ============================================
# These are automatically set by deployment platforms
# RAILWAY_ENVIRONMENT=production  # Set by Railway
# RENDER=true                      # Set by Render
# AWS_EXECUTION_ENV=AWS_ECS_FARGATE  # Set by AWS

# ============================================
# NOTES:
# ============================================
# 1. NEVER commit this file to Git with real values
# 2. Add .env to your .gitignore file
# 3. Use strong passwords for DATABASE_URL
# 4. Rotate TOTP_SECRET periodically
# 5. Use live Paystack keys only in production
# 6. Keep Brevo API key secure
